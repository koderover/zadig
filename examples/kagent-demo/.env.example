# OpenAI Chat Completions compatible backend.
# Examples: internal model gateway, vLLM OpenAI-compatible server, compatible hosted API.
MODEL_PROVIDER=openai
MODEL_BASE_URL=https://models.example.com/v1
MODEL_API_KEY=replace-me
MODEL_NAME=devops-assistant
MODEL_TIMEOUT=30s

